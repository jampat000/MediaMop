# Optional: absolute API origin for production / ``vite preview`` when web and API differ.
# Ignored during ``vite dev`` — the browser always uses same-origin ``/api`` (dev proxy).
# VITE_API_BASE_URL=https://api.example.com

# Override backend target for the dev proxy (defaults: scripts/dev-ports.json).
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8788
