# Optional: absolute API origin for builds that talk to the backend on another host.
# Dev default: leave unset and use the Vite ``/api`` proxy (same-origin cookies).
# VITE_API_BASE_URL=http://127.0.0.1:8788

# Override backend target for the dev proxy (defaults: scripts/dev-ports.json).
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8788
