# MediaMop Docker environment example.
# Copy this file to `.env.mediamop` in the repository root if you want to override defaults:
#   docker compose --env-file .env.mediamop up -d

# Optional. If omitted, the container generates a high-entropy secret and persists it to:
#   $MEDIAMOP_HOME/session.secret
# To create your own:
#   openssl rand -hex 32
# MEDIAMOP_SESSION_SECRET=

# Recommended before saving Pruner, Subber, Sonarr, or Radarr credentials.
# Generate a different value from MEDIAMOP_SESSION_SECRET:
#   openssl rand -hex 32
# MEDIAMOP_CREDENTIALS_SECRET=

# Persistent data root inside the container. The default compose volume maps this path.
# MEDIAMOP_HOME=/data/mediamop

# Optional image override.
# MEDIAMOP_DOCKER_IMAGE=ghcr.io/jampat000/mediamop:latest

# Default image uses HTTP-friendly cookies for localhost/LAN use.
# Set true only when every browser reaches MediaMop through HTTPS.
# MEDIAMOP_SESSION_COOKIE_SECURE=false

# Optional reverse proxy trust. Only set this to the immediate trusted proxy IP/CIDR.
# MEDIAMOP_TRUSTED_PROXY_IPS=
